# Gaffer Configuration
# Copy to .env and uncomment the values you want to override.

# Data provider: "live" (default, hits fantasy.premierleague.com/api/) or "csv" (bundled historical)
# GAFFER_DATA_SOURCE=live

# Cache directory (default: data/cache relative to project root)
# GAFFER_CACHE_DIR=data/cache

# Cache TTL for bootstrap-static (hours)
# GAFFER_BOOTSTRAP_TTL_HOURS=6

# Cache TTL for fixtures (hours)
# GAFFER_FIXTURES_TTL_HOURS=24

# Optimizer horizon in gameweeks (1-5)
# GAFFER_HORIZON=3

# MILP solver time limit in seconds
# GAFFER_SOLVER_TIME_LIMIT=60

# EWMA smoothing factor for rolling player stats
# GAFFER_EWMA_ALPHA=0.95
